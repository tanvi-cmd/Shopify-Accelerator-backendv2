#############################################
# Application
#############################################

NODE_ENV=development
PORT=3000

#############################################
# AWS
#############################################

AWS_REGION=us-east-1

#############################################
# Logging
#############################################

LOG_LEVEL=info

#############################################
# Database
#############################################

DATABASE_URL=

#############################################
# Authentication
#############################################

JWT_SECRET=

#############################################
# Redis (Optional)
#############################################

REDIS_URL=

#############################################
# AWS S3 (Optional)
#############################################

AWS_S3_BUCKET=

#############################################
# AWS SES (Optional)
#############################################

AWS_SES_REGION=
AWS_SES_FROM_EMAIL=

#############################################
# CloudWatch
#############################################

ENABLE_CLOUDWATCH=false